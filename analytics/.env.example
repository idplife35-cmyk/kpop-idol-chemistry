# GA4 numeric property ID (NOT the G-XXXX measurement ID)
# Captured 2026-06-10 — kept here even though service-account key creation
# is currently blocked by the org policy iam.disableServiceAccountKeyCreation.
# If/when an alternate auth path is enabled (Workload Identity Federation,
# OAuth refresh token, or a personal-account GCP project), this value lights up
# the ga_client.mjs path immediately.
GA4_PROPERTY_ID=506354216

# Optional: YouTube Data API key for the trend_pull YouTube axis.
# Without this, trend_pull continues with Reddit + Wikipedia only.
# YOUTUBE_API_KEY=
