---
interface Member {
  id: string;
  nameKr: string;
  nameEn: string;
  gender: 'male' | 'female';
  position?: string[];
  image?: string;
  emoji?: string;
}

interface Props {
  members: Member[];
  groupName: string;
  groupSlug: string;
  groupColor?: string;
}

// Image policy (per meetings/2026-06-09-image-strategy.md):
// real-person photos and AI lookalikes are forbidden — abstract avatars
// are the fallback that ships everywhere.
const { members, groupName, groupSlug, groupColor } = Astro.props;

function lighten(hex: string, amount = 0.25): string {
  const c = hex.replace('#', '');
  if (c.length !== 6) return hex;
  const r = Math.min(255, parseInt(c.slice(0, 2), 16) + Math.round(255 * amount));
  const g = Math.min(255, parseInt(c.slice(2, 4), 16) + Math.round(255 * amount));
  const b = Math.min(255, parseInt(c.slice(4, 6), 16) + Math.round(255 * amount));
  return `#${[r, g, b].map((x) => x.toString(16).padStart(2, '0')).join('')}`;
}

const gradientFrom = groupColor || 'var(--accent)';
const gradientTo = groupColor ? lighten(groupColor, 0.25) : 'var(--accent-2)';
---

<div class="member-grid">
  <h3 class="grid-title">👥 {groupName} Members</h3>
  <p class="grid-subtitle">Click a member to test your chemistry!</p>
  <div class="members">
    {members.map((member) => (
      <a
        href={`/${groupSlug}-name-generator/${member.id}/`}
        class="member-card"
      >
        <div
          class="member-avatar"
          style={`background: linear-gradient(135deg, ${gradientFrom}, ${gradientTo});`}
        >
          {member.image ? (
            <img src={member.image} alt={member.nameEn} loading="lazy" />
          ) : member.emoji ? (
            <span class="avatar-emoji" aria-hidden="true">{member.emoji}</span>
          ) : (
            <span class="avatar-initial">{member.nameEn[0]}</span>
          )}
        </div>
        <div class="member-info">
          <span class="member-name-en">{member.nameEn}</span>
          <span class="member-name-kr">{member.nameKr}</span>
        </div>
        <span class="member-arrow">→</span>
      </a>
    ))}
  </div>
</div>

<style>
  .member-grid {
    margin: 24px 0;
  }
  
  .grid-title {
    font-size: 1.1rem;
    margin-bottom: 4px;
    color: var(--text);
  }

  .grid-subtitle {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 16px;
  }
  
  .members {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
  }
  
  .member-card {
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px;
    cursor: pointer;
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    text-decoration: none;
    position: relative;
  }
  
  .member-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(255, 46, 139, 0.2);
  }

  .member-card:hover .member-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .member-arrow {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 0.8rem;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s ease;
  }
  
  .member-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.2s ease;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.35);
  }

  .avatar-emoji {
    font-size: 1.65rem;
    line-height: 1;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.25));
  }

  .member-card:hover .member-avatar {
    transform: scale(1.05);
  }
  
  .member-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .avatar-initial {
    color: white;
    font-size: 1.5rem;
    font-weight: 700;
  }
  
  .member-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  
  .member-name-en {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
  }
  
  .member-name-kr {
    font-size: 0.8rem;
    color: var(--muted);
  }
  
  @media (max-width: 480px) {
    .members {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    
    .member-card {
      padding: 8px;
    }
    
    .member-avatar {
      width: 44px;
      height: 44px;
    }
    
    .avatar-initial {
      font-size: 1.2rem;
    }
    
    .member-name-en {
      font-size: 0.8rem;
    }
    
    .member-name-kr {
      font-size: 0.7rem;
    }

    .member-arrow {
      display: none;
    }
  }
</style>




